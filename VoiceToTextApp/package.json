{
  "name": "voicetotextapp",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "eas:link": "eas init",
    "eas:update:configure": "eas update:configure",
    "eas:build:preview": "eas build --profile preview",
    "eas:build:production": "eas build --profile production",
    "eas:update:preview": "eas update --channel preview",
    "eas:update:production": "eas update --channel production",
    "eas:submit": "eas submit --profile production",
    "release:android": "eas build --profile production --platform android",
    "release:ios": "eas build --profile production --platform ios",
    "release:ota": "eas update --channel production --message \"JS OTA\""
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.0.2",
    "expo": "~54.0.33",
    "expo-av": "~16.0.8",
    "expo-file-system": "~19.0.21",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eas-cli": "^16.28.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
