{
  "name": "voicetotextapp",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "verify:env": "node ./scripts/verify-expo-env.js",
    "eas:link": "npx eas-cli init",
    "eas:update:configure": "npx eas-cli update:configure",
    "eas:build:preview": "npx eas-cli build --profile preview",
    "eas:build:production": "npx eas-cli build --profile production",
    "eas:update:preview": "npx eas-cli update --channel preview",
    "eas:update:production": "npx eas-cli update --channel production",
    "eas:submit": "npx eas-cli submit --profile production",
    "release:android": "npx eas-cli build --profile production --platform android",
    "release:ios": "npx eas-cli build --profile production --platform ios",
    "release:ota": "npx eas-cli update --channel production --message \"JS OTA\""
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.34",
    "expo-av": "~16.0.8",
    "expo-file-system": "~19.0.22",
    "expo-font": "~14.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-location": "~19.0.8",
    "expo-speech": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.17",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
