# --- Expo app (VoiceToTextApp/.env) -------------------------------------------
# 1) EXPO_PUBLIC_TRANSCRIBE_API_URL should be your API origin + /transcribe (same Cloud Run / Functions URL as the server).
#    Example after deploy: https://<hash>-uc.a.run.app/transcribe
# 2) EXPO_PUBLIC_TRANSCRIBE_API_TOKEN must exactly match SERVER_BEARER_TOKEN on the API when auth is enabled.
# 3) After changing .env: restart Expo (npm start). Run: npm run verify:env
#
# To wipe AI blocks server-side: redeploy API, then use the app AI tab “Clear all AI notes…” or POST /history/clear-ai.
# ---------------------------------------------------------------------------
EXPO_PUBLIC_TRANSCRIBE_API_URL=https://your-api.example.com/transcribe
EXPO_PUBLIC_TRANSCRIBE_API_TOKEN=your_optional_bearer_token
# Match server SPEAKER_MATCH_THRESHOLD (default 0.97) for conflict prompts; must not exceed server threshold.
EXPO_PUBLIC_SPEAKER_MIN_CONFIDENCE=0.97
