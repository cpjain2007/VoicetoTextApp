# --- AI in the mobile app (2 things) -----------------------------------------
# 1) Set OPENAI_API_KEY below (and on Firebase: Functions → api → OPENAI_API_KEY).
# 2) In VoiceToTextApp/.env set EXPO_PUBLIC_TRANSCRIBE_API_URL (same host as this API) and
#    EXPO_PUBLIC_TRANSCRIBE_API_TOKEN to match SERVER_BEARER_TOKEN when auth is enabled.
#
# Deploy: from repo root, run: npx firebase-tools deploy --only functions
# Clear AI fields on all saved transcripts (auth required): POST /history/clear-ai
# Regenerate AI for one saved entry (body: {"id":"<firestore doc id or clientId>"}): POST /history/regenerate-ai
# Verify locally: npm run verify:ai
# ---------------------------------------------------------------------------
# Optional local only — do not set PORT if you use the same file for Firebase (PORT is reserved on Cloud Functions).
# PORT=3001
SPEAKER_STORE_BACKEND=file
SPEAKER_FIRESTORE_DOC=apiState/speakerProfiles
# Powers transcript summaries/topics, /ai/insights, and AI tab backfill in the app.
OPENAI_API_KEY=your_openai_api_key_here
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here
ASSEMBLYAI_FORCE_LANGUAGE_CODE=
ASSEMBLYAI_LANGUAGE_FALLBACKS=hi,te,bn
# Set to false to disable mapping utterances to enrolled names (Universal-3 Pro / Universal-2 only).
ASSEMBLYAI_SPEAKER_IDENTIFICATION=true
# Max distinct names sent to AssemblyAI Speaker Identification (each name max 35 chars).
ASSEMBLYAI_SPEAKER_ID_MAX_NAMES=20
SERVER_BEARER_TOKEN=your_custom_token_here
# Cosine match vs stored voice fingerprint (12-D). Default 0.95 balances recall and precision.
SPEAKER_MATCH_THRESHOLD=0.95
# When second-best profile is still strong (>= SPEAKER_MATCH_SECOND_STRONG_MIN), require at least this
# gap vs best or we return no match (avoids confused similar voices). Default 0.025.
# SPEAKER_MATCH_MIN_GAP_BETWEEN_PROFILES=0.025
# SPEAKER_MATCH_SECOND_STRONG_MIN=0.84
# Accept a very strong top match even when the runner-up is close.
# SPEAKER_MATCH_HIGH_CONFIDENCE_OVERRIDE=0.995
# Optional real speaker embedding service. When configured, embeddings are used before fingerprint matching.
# SPEAKER_EMBEDDING_SERVICE_URL=https://your-cloud-run-service.run.app
# SPEAKER_EMBEDDING_SERVICE_TOKEN=shared_secret_between_api_and_embedding_service
# SPEAKER_EMBEDDING_MATCH_THRESHOLD=0.55
# SPEAKER_EMBEDDING_MATCH_MARGIN=0.05
# SPEAKER_EMBEDDING_HIGH_CONFIDENCE_OVERRIDE=0.75
# Max time the API waits for embeddings before falling back to fingerprint matching.
# SPEAKER_EMBEDDING_TIMEOUT_MS=18000
# Relaxed tier (below): on by default to avoid missing enrolled speakers when recording conditions change.
SPEAKER_MATCH_RELAXED_ENABLED=true
# If best score is below SPEAKER_MATCH_THRESHOLD but clearly ahead of the 2nd-best profile, still accept.
# Defaults to max(0.86, SPEAKER_MATCH_THRESHOLD - 0.08). Set explicitly to tune recall vs confusion.
# SPEAKER_MATCH_RELAXED_THRESHOLD=0.87
# Minimum gap between best and second-best cosine (only used when SPEAKER_MATCH_RELAXED_ENABLED=true).
# SPEAKER_MATCH_MARGIN=0.04
# Rolling list of recent fingerprints per enrolled speaker (max-cosine match). Range 1–12.
SPEAKER_RECENT_VECTORS_MAX=5
# Max length of optional AssemblyAI per-speaker description (from profile speakerDescription / description).
ASSEMBLYAI_SPEAKER_DESCRIPTION_MAX=220
MAX_UPLOAD_MB=25
# Optional cap on floats returned per embedding vector in GET /speakers (default 1024).
# PUBLIC_SPEAKER_EMBEDDING_MAX_LENGTH=1024
# POST /traffic/duration (Driving, traffic-aware). Enable Directions API + billing in Google Cloud.
# Deployed (Firebase Gen2): Secret Manager only — do not set GOOGLE_MAPS_API_KEY in .env or .env.<project> (deploy overlap error).
#   firebase functions:secrets:set GOOGLE_MAPS_API_KEY
# Then: npx firebase-tools deploy --only functions
# Use a server/browser key: enable “Directions API” + billing. Do not use an Android/iOS app–restricted key for Cloud Run.
# Local dev: use .env.local for GOOGLE_MAPS_API_KEY (gitignored).
# GOOGLE_MAPS_API_KEY=
OPENAI_AI_MODEL=gpt-4o-mini
